{
	admin 0.0.0.0:2019
	# Disable auto-HTTPS — we handle SSL termination at the edge (Cloudflare or manually)
	auto_https off
}

# Handle ALL incoming requests on port 80
# Caddy matches routes in order — subdomain routes are prepended dynamically via admin API
# The base domain and unmatched subdomains fall through to the handlers below
:80 {
	# ── Dynamic subdomain routes are inserted HERE via admin API ──
	# Example injected route (added by backend when user sets subdomain):
	# { "match": [{"host": ["myapp.1.2.3.4.sslip.io"]}], "handle": [...reverse_proxy...] }

	# ── Dashboard: serve frontend on base domain or direct IP ──
	handle /api/* {
		reverse_proxy backend:8000
	}

	handle {
		root * /srv/frontend
		try_files {path} /index.html
		file_server
	}
}
