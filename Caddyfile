{
	admin 0.0.0.0:2019
	auto_https off
}

# Caddy listens on port 80.
# Cloudflare Tunnel sends all traffic here.
# Subdomain routes are prepended dynamically by the backend via Caddy admin API.
# Each route matches a specific Host header like: myapp.yourdomain.com
:80 {
	# ── Dynamic subdomain routes are inserted above these handlers ──
	# They have "terminal": true so they short-circuit before reaching /api/* or file_server

	handle /api/* {
		reverse_proxy backend:8000
	}

	handle {
		root * /srv/frontend
		try_files {path} /index.html
		file_server
	}
}
